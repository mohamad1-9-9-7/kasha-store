# ════════════════════════════════════════════════════════════
# هذا ملف مثال — انسخه إلى .env (لا تضع أسراراً حقيقية هنا)
# cp .env.example .env
# ════════════════════════════════════════════════════════════

# Neon PostgreSQL connection string
# neon.tech → Project → Connection Details
DATABASE_URL=postgresql://user:password@host/db?sslmode=require

# JWT secret — يجب أن تكون سلسلة عشوائية طويلة (32+ حرف)
# ولّدها بـ: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=REPLACE_WITH_LONG_RANDOM_SECRET

# Admin credentials
# إما ADMIN_PASSWORD (نص) أو ADMIN_PASSWORD_HASH (bcrypt) — الأفضل الثاني
# لتوليد hash: node -e "console.log(require('bcryptjs').hashSync('your_password', 10))"
ADMIN_PHONE=05XXXXXXXX
ADMIN_PASSWORD=REPLACE_WITH_STRONG_PASSWORD
# ADMIN_PASSWORD_HASH=$2a$10$...

# عنوان/عناوين الواجهة — افصل بفاصلة لعدة مواقع
FRONTEND_URL=https://your-frontend.vercel.app

PORT=3001
